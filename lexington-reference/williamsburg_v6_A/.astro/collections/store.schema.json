{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "price": {
      "type": "string"
    },
    "checkout": {
      "type": "string"
    },
    "returns": {
      "type": "string"
    },
    "shipping": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "thumbnail": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "alt"
      ],
      "additionalProperties": false
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "additionalProperties": false
      }
    },
    "testimonials": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "img": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "date",
          "text",
          "img"
        ],
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category",
    "price",
    "checkout",
    "license",
    "description",
    "highlights",
    "thumbnail",
    "tags"
  ],
  "additionalProperties": false
}