{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "client": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "year": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "concept",
        "in-progress",
        "built"
      ]
    },
    "area": {
      "type": "string"
    },
    "cover": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "alt"
      ],
      "additionalProperties": false
    },
    "gallery": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "additionalProperties": false
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ],
  "additionalProperties": false
}