<section class="sandstone-blog padding-block">
  <div class="page-width">
    <div class="blog-header">
      <p class="kicker">Journal</p>
      <p class="blog-title">Explore our latest articles and insights on design, technology, and creative innovation</p>
      <a href="#" class="rolling-link">See all articles</a>
    </div>

    <div class="blog-grid">
      <div class="blog-card">
        <div class="blog-image-wrapper">
          <img src="{{ 'sandstone-blog-1.png' | asset_url }}" alt="Blog 1" loading="lazy" width="800" height="600">
        </div>
        <div class="blog-content">
          <p class="blog-date">November 12, 2025</p>
          <h3 class="blog-heading">Human-Centered Architecture</h3>
          <p class="blog-excerpt">How architects translate vision into space, blending context, materiality, and technology to shape environments that elevate daily life.</p>
        </div>
      </div>
      <div class="blog-card">
        <div class="blog-image-wrapper">
          <img src="{{ 'sandstone-blog-2.png' | asset_url }}" alt="Blog 2" loading="lazy" width="800" height="600">
        </div>
        <div class="blog-content">
          <p class="blog-date">October 22, 2025</p>
          <h3 class="blog-heading">Breathing new life into existing structures</h3>
          <p class="blog-excerpt">Strategies for transforming legacy buildings into high-performance spaces without erasing their character.</p>
        </div>
      </div>
      <div class="blog-card">
        <div class="blog-image-wrapper">
          <img src="{{ 'sandstone-blog-3.png' | asset_url }}" alt="Blog 3" loading="lazy" width="800" height="600">
        </div>
        <div class="blog-content">
          <p class="blog-date">September 14, 2025</p>
          <h3 class="blog-heading">Architecture that supports well-being</h3>
          <p class="blog-excerpt">Evidence-based design moves that help healthcare and workplace projects nurture calm, connection, and recovery.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sandstone-blog {
    padding-top: 6rem;
    padding-bottom: 6rem;
    background-color: #fff;
  }
  .blog-header {
    margin-bottom: 3rem;
  }
  .blog-title {
    font-size: clamp(2rem, 3vw, 2.5rem);
    line-height: 1.1;
    font-weight: 500;
    max-width: 600px;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }
  @media screen and (min-width: 990px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .blog-image-wrapper {
    overflow: hidden;
    border-radius: 0.75rem;
  }
  .blog-image-wrapper img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .blog-card:hover .blog-image-wrapper img {
    transform: scale(1.05);
  }
  .blog-date {
    font-size: 0.875rem;
    color: #4b5563;
    margin-bottom: 0.5rem;
  }
  .blog-heading {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .blog-excerpt {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Sandstone Blog Preview",
  "presets": [
    {
      "name": "Sandstone Blog Preview"
    }
  ]
}
{% endschema %}