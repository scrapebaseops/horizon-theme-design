<section class="sandstone-services padding-block">
  <div class="page-width">
    <div class="services-container">
      <div class="services-images">
        <img src="{{ 'sandstone-service-1.png' | asset_url }}" alt="Service 1" class="service-img" loading="lazy">
      </div>
      <div class="services-content">
        <div class="services-content-inner">
          <p class="kicker">Services</p>
          <p class="services-title">Leading sustainable interior design services that integrate ecofriendly materials and energy efficient solutions.</p>
          
          <div class="services-list">
            <button class="service-btn active">Eco-Materials Selection</button>
            <button class="service-btn">Energy-Efficient Systems</button>
            <button class="service-btn">Environmental Impact Assessment</button>
          </div>
          
          <p class="service-desc">Curated selection of sustainable, low-impact interior materials that meet both environmental and aesthetic standards.</p>
          <a href="#" class="rolling-link mt-8">See all services</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .sandstone-services {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  .services-container {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    height: calc(100vh - 2rem);
    min-height: 600px;
    background-color: #f3f4f6;
  }
  .services-images {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .service-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .services-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1rem;
  }
  @media screen and (min-width: 990px) {
    .services-content {
      max-width: 36rem;
      margin-left: auto;
    }
  }
  .services-content-inner {
    background-color: var(--color-background);
    padding: 2rem;
    border-radius: 1rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .services-title {
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 500;
    margin-top: 3rem;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }
  .services-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }
  .service-btn {
    text-align: left;
    width: 100%;
    padding: 0.5rem 0;
    background: none;
    border: none;
    font-size: 1.125rem;
    font-weight: 500;
    color: #111827;
    cursor: pointer;
    opacity: 0.5;
    transition: all 0.3s ease;
  }
  .service-btn.active {
    opacity: 1;
    transform: translateX(1rem);
  }
  .service-desc {
    margin-top: 2rem;
    font-size: 1rem;
    color: #4b5563;
  }
  .mt-8 {
    margin-top: 2rem;
    display: inline-block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Sandstone Services",
  "presets": [
    {
      "name": "Sandstone Services"
    }
  ]
}
{% endschema %}