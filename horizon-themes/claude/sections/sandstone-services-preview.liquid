<section class="sandstone-section--overflow">
  <div class="sandstone-container--wide sandstone-section--tight">
    <div class="sandstone-services-shell">
      {%- for block in section.blocks -%}
        <img
          src="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 2000 }}{% else %}{{ 'sandstone-service-' | append: forloop.index | append: '.png' | asset_url }}{% endif %}"
          alt="{{ block.settings.title }}"
          class="sandstone-services-bg"
          id="sandstone-service-img-{{ forloop.index0 }}"
          loading="lazy"
          {%- unless forloop.first %} style="display: none;"{% endunless %}
        >
      {%- endfor -%}

      <div class="sandstone-services-panel-wrap">
        <div class="sandstone-services-panel">
          {% render 'sandstone-kicker', text: section.settings.kicker %}
          <p class="sandstone-display-text sandstone-display-sm sandstone-heading sandstone-mt-xl sandstone-display-text--tight">
            {{ section.settings.heading }}
          </p>

          <div class="sandstone-divider-list sandstone-mt-lg">
            {%- for block in section.blocks -%}
              <button
                type="button"
                class="sandstone-services-tab sandstone-divider-list__item{% unless forloop.first %} sandstone-services-tab--muted{% endunless %}"
                data-sandstone-service-tab="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <p class="sandstone-services-tab__title">{{ block.settings.title }}</p>
              </button>
            {%- endfor -%}
          </div>

          <p class="sandstone-services-description" id="sandstone-service-description">
            {% for block in section.blocks limit: 1 %}{{ block.settings.description }}{% endfor %}
          </p>

          {%- liquid
            assign services_cta_href = section.settings.cta_url | default: '/pages/services'
          -%}
          {% render 'sandstone-rolling-link', href: services_cta_href, text: section.settings.cta_text, hover_text: section.settings.cta_hover_text %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var tabs = document.querySelectorAll('[data-sandstone-service-tab]');
    var images = document.querySelectorAll('.sandstone-services-bg');
    if (!tabs.length) return;
    tabs.forEach(function(tab, index) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t, i) { t.classList.toggle('sandstone-services-tab--muted', i !== index); });
        images.forEach(function(img, i) { img.style.display = i === index ? 'block' : 'none'; });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Sandstone Services",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Services" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Leading sustainable interior design services that integrate ecofriendly materials and energy efficient solutions." },
    { "type": "url", "id": "cta_url", "label": "See all link" },
    { "type": "text", "id": "cta_text", "label": "See all — text", "default": "See all services" },
    { "type": "text", "id": "cta_hover_text", "label": "See all — hover text", "default": "Explore now" }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "image_picker", "id": "image", "label": "Background image" }
      ]
    }
  ],
  "presets": [{ "name": "Sandstone Services" }]
}
{% endschema %}
