{%- liquid
  assign title = section.settings.heading
  if title == blank
    case template.name
      when 'collection'
        assign title = collection.title
      when 'list-collections'
        assign title = 'Collections'
      when 'blog'
        assign title = blog.title
      when 'article'
        assign title = article.title
      when 'search'
        assign title = 'Search'
      when 'cart'
        assign title = 'Cart'
      when '404'
        assign title = 'Page not found'
      when 'page'
        assign title = page.title
      else
        assign title = page_title | default: shop.name
    endcase
  endif

  assign subheading_display = section.settings.subheading
  if subheading_display == blank and template.name == 'collection' and collection.description != blank
    assign subheading_display = collection.description
  endif
-%}
<section class="sandstone-page-hero sandstone-section">
  <div class="sandstone-container">
    {% if section.settings.kicker != blank %}
      <p class="sandstone-kicker">{{ section.settings.kicker }}</p>
    {% endif %}
    <h1 class="sandstone-display-xl sandstone-heading sandstone-page-hero__heading">
      {{ title }}
    </h1>
    {% if subheading_display != blank %}
      <div class="sandstone-text-lg sandstone-body sandstone-mt-md sandstone-text-balance rte">{{ subheading_display }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Sandstone Page hero",
  "tag": "section",
  "class": "sandstone-page-hero-section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker" },
    { "type": "text", "id": "heading", "label": "Heading", "info": "Leave blank to use the page title, collection name, blog title, or search label automatically." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "presets": [{ "name": "Sandstone Page hero" }]
}
{% endschema %}
