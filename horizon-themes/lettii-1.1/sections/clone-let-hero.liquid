{{ 'clone-let-styles.css' | asset_url | stylesheet_tag }}

<section class="clone-let-section">
  <div class="clone-let-wrapper clone-let-pt-32 clone-let-pb-4">
    <div class="clone-let-text-center clone-let-text-balance">
      <h1 class="clone-let-display-md clone-let-text-black">
        {{ section.settings.heading | default: 'Email delivery that doesn&rsquo;t suck and won&rsquo;t vanish into the spam abyss' }}
      </h1>
      <p class="clone-let-text-base clone-let-text-base-500 clone-let-max-w-xl clone-let-mx-auto clone-let-mt-4">
        {{ section.settings.subheading | default: 'Stop wondering if your transactional and marketing emails made it. Send at scale, hit inboxes, and skip the mystery.' }}
      </p>
    </div>
    <div class="clone-let-flex-wrap clone-let-mt-10 clone-let-gap-2">
      <a href="{{ section.settings.primary_cta_url | default: '#' }}" class="clone-let-btn clone-let-btn--sm clone-let-btn--accent">
        {{ section.settings.primary_cta_text | default: 'Get started' }}
      </a>
      <a href="{{ section.settings.secondary_cta_url | default: '#' }}" class="clone-let-btn clone-let-btn--sm clone-let-btn--muted">
        {{ section.settings.secondary_cta_text | default: 'Start free trial' }}
      </a>
    </div>
    {% if section.settings.hero_image %}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1440 }}"
        alt="{{ section.settings.hero_image.alt | default: 'Hero image' }}"
        class="clone-let-w-full clone-let-rounded-xl clone-let-mt-8"
        width="1440"
        height="auto"
        loading="eager"
      >
    {% else %}
      <div class="clone-let-w-full clone-let-rounded-xl clone-let-mt-8" style="background: var(--clone-sand-100); aspect-ratio: 16/9;"></div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Clone: Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Email delivery that doesn't suck and won't vanish into the spam abyss"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Stop wondering if your transactional and marketing emails made it. Send at scale, hit inboxes, and skip the mystery."
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "Get started"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Start free trial"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Clone: Hero"
    }
  ]
}
{% endschema %}
