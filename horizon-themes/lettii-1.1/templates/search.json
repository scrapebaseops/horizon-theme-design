{
  "sections": {
    "search_header": {
      "type": "search-header",
      "blocks": {
        "heading": {
          "type": "_heading",
          "static": true,
          "settings": {
            "type_preset": "h2",
            "font": "var(--font-primary--family)",
            "alignment": "center"
          }
        },
        "search": {
          "type": "_search-input",
          "static": true,
          "settings": {
            "width": "custom",
            "custom_width": 60,
            "inherit_color_scheme": true
          }
        }
      },
      "settings": {
        "alignment": "center",
        "color_scheme": "scheme-2",
        "padding-block-start": 48,
        "padding-block-end": 24
      }
    },
    "main": {
      "type": "search-results",
      "blocks": {
        "filters": {
          "type": "filters",
          "static": true,
          "settings": {
            "enable_filtering": true,
            "filter_style": "horizontal",
            "filter_width": "centered",
            "enable_sorting": true,
            "enable_grid_density": true,
            "inherit_color_scheme": true,
            "padding-block-start": 8,
            "padding-block-end": 8
          }
        },
        "product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 8,
            "border_radius": 16
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": { "image_ratio": "portrait", "border_radius": 16 }
            },
            "product_title": {
              "type": "product-title",
              "settings": {
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "padding-block-start": 4
              }
            },
            "price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "show_installments": false,
                "type_preset": "h6",
                "alignment": "left",
                "font": "var(--font-body--family)"
              }
            }
          },
          "block_order": ["gallery", "product_title", "price"]
        }
      },
      "settings": {
        "layout_type": "grid",
        "product_card_size": "medium",
        "mobile_product_card_size": "small",
        "enable_infinite_scroll": true,
        "product_grid_width": "centered",
        "full_width_on_mobile": true,
        "columns_gap_horizontal": 12,
        "columns_gap_vertical": 24,
        "color_scheme": "scheme-1",
        "padding-block-start": 24,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "search_header",
    "main"
  ]
}
