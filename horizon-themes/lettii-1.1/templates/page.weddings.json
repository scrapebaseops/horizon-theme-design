    "faq": {
      "type": "clone-let-faq",
      "blocks": {
        "q1": { "type": "question", "settings": { "question": "Can I rent lamps instead of buying?", "answer": "We don't currently offer rental. For one-off events, many customers buy and then resell or gift the lamps after — they're a genuinely useful item to keep." } },
        "q2": { "type": "question", "settings": { "question": "How far in advance should I order?", "answer": "We recommend 3-4 weeks before your event for standard orders. If you need 50+ lamps, 6 weeks gives us plenty of time. Rush orders may be possible — mention your date in the enquiry." } },
        "q3": { "type": "question", "settings": { "question": "Can I test one before ordering for my full event?", "answer": "Yes. Order a single lamp from our shop at retail price to test. If you then place a bulk order, we'll credit the cost." } },
        "q4": { "type": "question", "settings": { "question": "Do you offer event styling advice?", "answer": "We can recommend quantities and suggest which designs suit your venue and theme. Tell us about your event in the enquiry form and we'll include suggestions." } },
        "q5": { "type": "question", "settings": { "question": "What if I order too many?", "answer": "Our 30-day money-back guarantee applies. Return any unused lamps in their original packaging for a full refund." } },
        "q6": { "type": "question", "settings": { "question": "Do the lamps come pre-charged?", "answer": "They arrive with a partial charge — enough to test. For your event, we recommend a full charge the day before (4-5 hours from flat to full)." } }
      },
      "block_order": ["q1", "q2", "q3", "q4", "q5", "q6"],
      "settings": {
        "heading": "Common event questions",
        "description": ""
      }
