          "type": "text",
          "settings": {
            "text": "<h1>Shipping & Delivery</h1>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "h2",
            "font": "var(--font-primary--family)"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "text": "<p>Everything you need to know about getting your Lettii lamp to your door.</p>",
