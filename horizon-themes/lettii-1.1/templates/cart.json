{
  "sections": {
    "main": {
      "type": "main-cart",
      "blocks": {
        "cart-title": {
          "type": "_cart-title",
          "static": true,
          "settings": {
            "title": "Your Cart",
            "show_count": true,
            "type_preset": "h4",
            "alignment": "left"
          }
        },
        "cart-items": {
          "type": "_cart-products",
          "static": true,
          "settings": {
            "gap": 24,
            "image_ratio": "portrait",
            "dividers": true,
            "vendor": false
          }
        },
        "cart-summary": {
          "type": "_cart-summary",
          "static": true,
          "settings": {
            "extend_summary": true,
            "inherit_color_scheme": false,
            "color_scheme": "scheme-2",
            "border": "none",
            "border_radius": 16
          }
        }
      },
      "settings": {
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 24,
        "padding-block-end": 24
      }
    },
    "cross_sell": {
      "type": "product-list",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "static": true,
          "settings": {
            "content_direction": "row",
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "align_baseline": true,
            "gap": 12,
            "width": "fill",
            "height": "fit",
            "inherit_color_scheme": true
          },
          "blocks": {
            "title": {
              "type": "_product-list-text",
              "settings": {
                "text": "<h3>You may also like</h3>",
                "type_preset": "h4",
                "alignment": "left"
              }
            },
            "view_all": {
              "type": "_product-list-button",
              "settings": {
                "label": "View all",
                "style_class": "link"
              }
            }
          },
          "block_order": ["title", "view_all"]
        },
        "static-product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 8,
            "border_radius": 16
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": { "image_ratio": "adapt", "border_radius": 16 }
            },
            "product_title": {
              "type": "product-title",
              "settings": { "type_preset": "rte", "font": "var(--font-body--family)", "padding-block-start": 4 }
            },
            "price": {
              "type": "price",
              "settings": { "show_sale_price_first": true, "show_installments": false, "type_preset": "h6" }
            }
          },
          "block_order": ["gallery", "product_title", "price"]
        }
      },
      "block_order": [],
      "settings": {
        "collection": "all-lamps",
        "layout_type": "grid",
        "max_products": 4,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 12,
        "rows_gap": 24,
        "section_width": "page-width",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "main",
    "cross_sell"
  ]
}
