{
  "sections": {
    "collection_hero": {
      "type": "let-collection-hero",
      "settings": {
        "heading": "",
        "description": "",
        "overlay_opacity": 40
      }
    },
    "trust_bar": {
      "type": "let-trust-bar",
      "blocks": {
        "item_1": { "type": "trust_item", "settings": { "icon": "shield", "text": "30-Day Guarantee" } },
        "item_2": { "type": "trust_item", "settings": { "icon": "truck", "text": "Free UK Shipping Over £50" } },
        "item_3": { "type": "trust_item", "settings": { "icon": "battery", "text": "12-Hour Battery, USB-C" } },
        "item_4": { "type": "trust_item", "settings": { "icon": "return", "text": "Free Returns" } }
      },
      "block_order": ["item_1", "item_2", "item_3", "item_4"],
      "settings": {}
    },
    "main": {
      "type": "main-collection",
      "blocks": {
        "filters": {
          "type": "filters",
          "static": true,
          "settings": {
            "enable_filtering": true,
            "filter_style": "horizontal",
            "filter_width": "centered",
            "text_label_case": "default",
            "show_swatch_label": false,
            "show_filter_label": false,
            "enable_sorting": true,
            "enable_grid_density": true,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "padding-block-start": 8,
            "padding-block-end": 8,
            "facets_margin_bottom": 8,
            "facets_margin_right": 20
          }
        },
        "product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 8,
            "inherit_color_scheme": true,
            "border_radius": 16
          },
          "blocks": {
            "card-gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "portrait",
                "border_radius": 16
              }
            },
            "product_title": {
              "type": "product-title",
              "settings": {
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "padding-block-start": 4
              }
            },
            "price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "show_installments": false,
                "type_preset": "h6",
                "alignment": "left",
                "font": "var(--font-body--family)"
              }
            },
            "swatches": {
              "type": "swatches",
              "settings": {
                "product_swatches_alignment": "flex-start",
                "product_swatches_padding_top": 4
              }
            }
          },
          "block_order": ["card-gallery", "product_title", "price", "swatches"]
        }
      },
      "settings": {
        "layout_type": "grid",
        "product_card_size": "medium",
        "mobile_product_card_size": "small",
        "enable_infinite_scroll": true,
        "products_per_page": 24,
        "product_grid_width": "centered",
        "full_width_on_mobile": true,
        "columns_gap_horizontal": 12,
        "columns_gap_vertical": 24,
        "color_scheme": "scheme-1",
        "padding-block-start": 16,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "collection_hero",
    "trust_bar",
    "main"
  ]
}
