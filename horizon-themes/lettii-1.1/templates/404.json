{
  "sections": {
    "main": {
      "type": "main-404",
      "blocks": {
        "heading": {
          "type": "text",
          "settings": {
            "text": "<h1>We can't find that page. But we can light the way back.</h1>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "h3",
            "font": "var(--font-primary--family)"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "text": "<p>The page you're looking for may have moved or no longer exists. Try searching for what you need, or explore our collections below.</p>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "rte",
            "padding-block-end": 16
          }
        },
        "cta": {
          "type": "button",
          "settings": {
            "label": "Continue shopping",
            "link": "/collections/all-lamps",
            "style_class": "button",
            "width": "fit-content"
          }
        }
      },
      "block_order": ["heading", "body", "cta"],
      "settings": {
        "content_direction": "column",
        "section_width": "page-width",
        "section_height": "small",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 16,
        "color_scheme": "scheme-1",
        "padding-block-start": 100,
        "padding-block-end": 60
      }
    },
    "featured_products": {
      "type": "product-list",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "static": true,
          "settings": {
            "content_direction": "row",
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "align_baseline": true,
            "gap": 12,
            "width": "fill",
            "height": "fit",
            "inherit_color_scheme": true
          },
          "blocks": {
            "title": {
              "type": "_product-list-text",
              "settings": {
                "text": "<h4>Worth a look</h4>",
                "type_preset": "h4",
                "alignment": "left"
              }
            },
            "view_all": {
              "type": "_product-list-button",
              "settings": {
                "label": "View all",
                "style_class": "link"
              }
            }
          },
          "block_order": ["title", "view_all"]
        },
        "static-product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 8,
            "border_radius": 16
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": { "image_ratio": "adapt", "border_radius": 16 }
            },
            "product_title": {
              "type": "product-title",
              "settings": { "type_preset": "rte", "font": "var(--font-body--family)", "padding-block-start": 4 }
            },
            "price": {
              "type": "price",
              "settings": { "show_sale_price_first": true, "show_installments": false, "type_preset": "h6" }
            }
          },
          "block_order": ["gallery", "product_title", "price"]
        }
      },
      "block_order": [],
      "settings": {
        "collection": "all-lamps",
        "layout_type": "grid",
        "max_products": 4,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 12,
        "rows_gap": 24,
        "section_width": "page-width",
        "horizontal_alignment": "center",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 0,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "main",
    "featured_products"
  ]
}
