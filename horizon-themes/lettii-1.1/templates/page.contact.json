{
  "sections": {
    "intro": {
      "type": "section",
      "blocks": {
        "heading": {
          "type": "text",
          "settings": {
            "text": "<h1>We're here. And we're quick.</h1>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "h2",
            "font": "var(--font-primary--family)"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "text": "<p>Whether it's a question about your order, help choosing the right lamp, or something else entirely — we'd love to hear from you.</p>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "rte"
          }
        }
      },
      "block_order": ["heading", "body"],
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 16,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 24
      }
    },
    "channels": {
      "type": "clone-let-features",
      "blocks": {
        "email": { "type": "feature", "settings": { "title": "Email", "description": "hello@lettii.co.uk — We reply within 12 hours, usually faster." } },
        "chat": { "type": "feature", "settings": { "title": "Live Chat", "description": "Monday - Friday, 9am - 6pm. Look for the chat icon in the bottom corner." } },
        "instagram": { "type": "feature", "settings": { "title": "Instagram DMs", "description": "@lettii.uk — Monitored daily. Quick questions welcome." } }
      },
      "block_order": ["email", "chat", "instagram"],
      "settings": {
        "heading": "",
        "description": ""
      }
    },
    "form": {
      "type": "section",
      "blocks": {
        "form_heading": {
          "type": "text",
          "settings": {
            "text": "<h2>Send us a message</h2>",
            "width": "100%",
            "alignment": "center",
            "type_preset": "h4",
            "padding-block-end": 8
          }
        },
        "contact_form": {
          "type": "contact-form",
          "settings": {
            "width": "custom",
            "custom_width": 50,
            "width_mobile": "custom",
            "custom_width_mobile": 100,
            "inherit_color_scheme": true
          },
          "blocks": {
            "submit-button": {
              "type": "contact-form-submit-button",
              "static": true,
              "settings": {
                "label": "Send Message",
                "style_class": "button",
                "width": "fit-content"
              }
            }
          },
          "block_order": []
        }
      },
      "block_order": ["form_heading", "contact_form"],
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 24,
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 32,
        "padding-block-end": 48
      }
    },
    "faq_redirect": {
      "type": "clone-let-cta",
      "settings": {
        "heading": "Looking for a quick answer?",
        "description": "Our FAQ covers shipping times, return policy, battery life, waterproofing, and everything else people ask most.",
        "cta_text": "View FAQ",
        "cta_url": "/pages/faq"
      }
    }
  },
  "order": [
    "intro",
    "channels",
    "form",
    "faq_redirect"
  ]
}
