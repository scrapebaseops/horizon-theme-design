    "feature_dinner": {
      "type": "media-with-content",
      "blocks": {
        "media": {
          "type": "_media-without-appearance",
          "static": true
        },
        "content": {
          "type": "_content-without-appearance",
          "static": true,
          "settings": {
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center"
          },
          "blocks": {
            "caption": {
              "type": "text",
              "settings": {
                "text": "<p>Setting 01</p>",
                "type_preset": "h6"
              }
            },
            "heading": {
              "type": "text",
              "settings": {
                "text": "<h2>The Perfect Dinner Party</h2>",
                "type_preset": "h3"
              }
            },
            "body": {
              "type": "text",
              "settings": {
                "text": "<p>The table's set. The wine's breathing. Now, the detail that separates a nice dinner from one people talk about — the light. Two or three Lettii lamps down the centre of a table do what candles do, without the wax, the smoke, or the midnight puddle on your tablecloth. Touch to dim as the evening unfolds. Your guests will notice.</p>",
                "type_preset": "rte",
                "max_width": "narrow"
              }
            },
            "cta": {
              "type": "button",
              "settings": {
                "label": "Shop Dining & Entertaining",
                "link": "/collections/dining-entertaining",
                "style_class": "link"
              }
            }
          },
          "block_order": ["caption", "heading", "body", "cta"]
        }
      },
      "settings": {
        "media_position": "left",
        "media_width": "wide",
        "media_height": "60svh",
        "section_width": "full-width",
        "color_scheme": "scheme-2",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "feature_garden": {
      "type": "media-with-content",
      "blocks": {
