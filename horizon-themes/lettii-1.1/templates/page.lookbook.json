            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "h1",
            "font": "var(--font-primary--family)"
          }
        },
        "subheading": {
          "type": "text",
          "settings": {
            "text": "<p>Ideas, settings, and stolen-from-a-restaurant style for every corner of your home.</p>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "rte"
          }
        }
      },
      "block_order": ["heading", "subheading"],
