          "type": "_content-without-appearance",
          "static": true,
          "settings": {
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center"
          },
          "blocks": {
            "caption": {
              "type": "text",
              "settings": {
                "text": "<p>Setting 03</p>",
                "type_preset": "h6"
              }
            },
            "heading": {
              "type": "text",
              "settings": {
                "text": "<h2>The Boutique Bedroom</h2>",
                "type_preset": "h3"
              }
            },
            "body": {
              "type": "text",
              "settings": {
                "text": "<p>You know the bedside lamp in every boutique hotel that makes you think \"why isn't my bedroom like this?\" That's a Lettii lamp. No cord hanging off the nightstand. No fumbling for a switch in the dark — just touch the top. The wireless freedom means you can move it from the bedside to the bathroom shelf to the landing windowsill.</p>",
                "type_preset": "rte",
                "max_width": "narrow"
              }
            },
            "cta": {
              "type": "button",
              "settings": {
                "label": "Shop Bedroom & Bedside",
                "link": "/collections/bedroom-bedside",
                "style_class": "link"
              }
            }
          },
          "block_order": ["caption", "heading", "body", "cta"]
        }
      },
      "settings": {
        "media_position": "left",
        "media_width": "wide",
        "media_height": "60svh",
        "section_width": "full-width",
