            "caption": {
              "type": "text",
              "settings": {
                "text": "<p>Setting 04</p>",
                "type_preset": "h6"
              }
            },
            "heading": {
              "type": "text",
              "settings": {
                "text": "<h2>Drinks & Conversation</h2>",
                "type_preset": "h3"
              }
            },
            "body": {
              "type": "text",
              "settings": {
                "text": "<p>Not every evening needs a three-course meal. Sometimes it's two friends, a bottle, and a kitchen island. A Lettii lamp on the counter or side table turns overhead lighting into background noise. It's the difference between \"come over for a drink\" and \"come over for a drink in a place that actually feels good.\"</p>",
                "type_preset": "rte",
                "max_width": "narrow"
              }
            },
            "cta": {
              "type": "button",
              "settings": {
                "label": "Shop All Lamps",
                "link": "/collections/all-lamps",
                "style_class": "link"
              }
            }
          },
          "block_order": ["caption", "heading", "body", "cta"]
        }
      },
