{
  "sections": {
    "main": {
      "type": "main-blog",
      "blocks": {
        "title": {
          "type": "text",
          "name": "Title",
          "settings": {
            "text": "<h1>{{ closest.blog.title }}</h1>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "left",
            "type_preset": "h2",
            "font": "var(--font-primary--family)",
            "padding-block-start": 48,
            "padding-block-end": 8
          }
        },
        "subtitle": {
          "type": "text",
          "name": "Subtitle",
          "settings": {
            "text": "<p>Styling ideas, setting guides, and the art of lighting well.</p>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "left",
            "type_preset": "rte",
            "padding-block-start": 0,
            "padding-block-end": 32
          }
        },
        "static-blog-post-card": {
          "type": "_blog-post-card",
          "static": true,
          "settings": {
            "alignment": "left"
          },
          "blocks": {
            "heading": {
              "type": "_heading",
              "static": true,
              "settings": {
                "type_preset": "h4",
                "font": "var(--font-primary--family)",
                "alignment": "left",
                "padding-block-end": 10
              }
            },
            "blog-post-details": {
              "type": "_blog-post-info-text",
              "static": true,
              "settings": {
                "show_date": true,
                "show_author": false,
                "alignment": "left"
              }
            },
            "image": {
              "type": "_blog-post-image",
              "static": true,
              "settings": {
                "height": "large",
                "border_radius": 16
              }
            }
          },
          "block_order": []
        }
      },
      "block_order": ["title", "subtitle"],
      "settings": {
        "color_scheme": "scheme-1",
        "padding-block-start": 0,
        "padding-block-end": 48
      }
    },
    "newsletter": {
      "type": "clone-let-subscribe",
      "settings": {
        "heading": "Stay in the glow.",
        "description": "Styling ideas, new lamp drops, and the occasional offer — straight to your inbox. No spam, just good light.",
        "label": "Email Address",
        "placeholder": "Your email address",
        "button_text": "Subscribe"
      }
    }
  },
  "order": [
    "main",
    "newsletter"
  ]
}
