{
  "sections": {
    "main": {
      "type": "product-information",
      "blocks": {
        "media-gallery": {
          "type": "_product-media-gallery",
          "static": true,
          "settings": {
            "media_presentation": "grid",
            "media_columns": "two",
            "image_gap": 4,
            "large_first_image": false,
            "icons_style": "arrow",
            "slideshow_controls_style": "counter",
            "slideshow_mobile_controls_style": "dots",
            "thumbnail_position": "right",
            "thumbnail_width": 44,
            "aspect_ratio": "adapt",
            "constrain_to_viewport": true,
            "media_fit": "contain",
            "media_radius": 0,
            "extend_media": false,
            "zoom": true,
            "video_loop": false,
            "hide_variants": true,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          }
        },
        "product-details": {
          "type": "_product-details",
          "static": true,
          "settings": {
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "details_position": "flex-start",
            "gap": 20,
            "sticky_details_desktop": true,
            "inherit_color_scheme": true,
            "color_scheme": "scheme-1",
            "background_media": "none",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "title_price_group": {
              "type": "group",
              "name": "Title & Price",
              "settings": {
                "content_direction": "column",
                "gap": 8,
                "width": "fill",
                "height": "fit",
                "inherit_color_scheme": true
              },
              "blocks": {
                "title": {
                  "type": "text",
                  "settings": {
                    "text": "<h1>{{ closest.product.title }}</h1>",
                    "type_preset": "h3",
                    "font": "var(--font-body--family)",
                    "alignment": "left"
                  }
                },
                "price": {
                  "type": "price",
                  "settings": {
                    "show_sale_price_first": true,
                    "show_installments": false,
                    "show_tax_info": false,
                    "type_preset": "paragraph",
                    "alignment": "left",
                    "font": "var(--font-body--family)"
                  }
                }
              },
              "block_order": ["title", "price"]
            },
            "value_prop": {
              "type": "text",
              "name": "Value proposition",
              "settings": {
                "text": "<p><em>Restaurant lighting, wherever you want it.</em></p>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "0.875rem",
                "alignment": "left",
                "color": "var(--color-foreground-secondary)",
                "padding-block-start": 0,
                "padding-block-end": 8
              }
            },
            "divider_1": {
              "type": "_divider",
              "settings": {
                "thickness": 1,
                "width_percent": 100,
                "padding-block-start": 4,
                "padding-block-end": 4
              }
            },
            "variant_picker": {
              "type": "variant-picker",
              "settings": {
                "variant_style": "buttons",
                "show_swatches": true,
                "alignment": "left",
                "padding-block-start": 0,
                "padding-block-end": 0
              }
            },
            "buy_buttons": {
              "type": "buy-buttons",
              "settings": {
                "stacking": true,
                "show_pickup_availability": false,
                "gift_card_form": true,
                "padding-block-start": 0,
                "padding-block-end": 0
              },
              "blocks": {
                "quantity": {
                  "type": "quantity",
                  "static": true,
                  "settings": {}
                },
                "add-to-cart": {
                  "type": "add-to-cart",
                  "static": true,
                  "settings": {
                    "style_class": "button"
                  }
                },
                "accelerated-checkout": {
                  "type": "accelerated-checkout",
                  "static": true,
                  "settings": {}
                }
              },
              "block_order": []
            },
            "b2b_link": {
              "type": "text",
              "name": "B2B link",
              "settings": {
                "text": "<p>Ordering for a restaurant, hotel, or event? <a href=\"/pages/hospitality\">Get a quote</a></p>",
                "type_preset": "rte",
                "font_size": "0.75rem",
                "alignment": "left",
                "padding-block-start": 4,
                "padding-block-end": 0
              }
            },
            "description": {
              "type": "text",
              "name": "Product description",
              "settings": {
                "text": "{{ closest.product.description }}",
                "width": "100%",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-primary--family)",
                "padding-block-start": 16,
                "padding-block-end": 0
              }
            }
          },
          "block_order": [
            "title_price_group",
            "value_prop",
            "divider_1",
            "variant_picker",
            "buy_buttons",
            "b2b_link",
            "description"
          ]
        }
      },
      "settings": {
        "content_width": "content-center-aligned",
        "desktop_media_position": "left",
        "equal_columns": false,
        "gap": 48,
        "enable_sticky_add_to_cart": true,
        "color_scheme": "scheme-1",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "trust_bar": {
      "type": "let-trust-bar",
      "blocks": {
        "item_1": { "type": "trust_item", "settings": { "icon": "shield", "text": "30-Day Guarantee" } },
        "item_2": { "type": "trust_item", "settings": { "icon": "return", "text": "Free Returns" } },
        "item_3": { "type": "trust_item", "settings": { "icon": "truck", "text": "Free Shipping Over £50" } },
        "item_4": { "type": "trust_item", "settings": { "icon": "water", "text": "IP54 Waterproof" } },
        "item_5": { "type": "trust_item", "settings": { "icon": "battery", "text": "12hr Battery" } }
      },
      "block_order": ["item_1", "item_2", "item_3", "item_4", "item_5"],
      "settings": {}
    },
    "faq": {
      "type": "clone-let-faq",
      "blocks": {
        "q1": { "type": "question", "settings": { "question": "Will it look premium or cheap?", "answer": "We spent months getting the finish right. No visible seams, no shiny plastic, no wobbly base. Every lamp has a weighted base and soft-touch shell. If you disagree, send it back within 30 days for a full refund." } },
        "q2": { "type": "question", "settings": { "question": "How long does the battery actually last?", "answer": "Up to 12 hours on a low setting — more than enough for a dinner party. On full brightness, around 6 hours. A full charge takes 4–5 hours via USB-C." } },
        "q3": { "type": "question", "settings": { "question": "Can I trust the quality from a brand I haven't heard of?", "answer": "Fair question. That's why every lamp comes with a 30-day money-back guarantee and free return shipping. Try it at home. If it's not what you expected, send it back — no questions, no cost." } },
        "q4": { "type": "question", "settings": { "question": "Is it bright enough to make a difference?", "answer": "It's designed to create atmosphere, not light a room. On the brightest setting (up to 180 lumens), it's enough to read by. On the lowest, it's a warm glow. Stepless dimming means you set it exactly where you want it." } },
        "q5": { "type": "question", "settings": { "question": "Can I use it outdoors? What about rain?", "answer": "Yes. Every Lettii lamp is rated IP54 — protected against splashing water from any direction. Light rain, a spilled glass, garden sprinklers — all fine." } },
        "q6": { "type": "question", "settings": { "question": "Why pay more than the £15 ones on Amazon?", "answer": "Those lamps exist, and they work. But they also look like they cost £15. Lettii sits between Amazon generics and £100+ designer lamps — you get design quality and warm light without the designer markup. Touch dimming, USB-C, IP54, 12-hour battery, and a 30-day guarantee." } }
      },
      "block_order": ["q1", "q2", "q3", "q4", "q5", "q6"],
      "settings": {
        "heading": "Common Questions",
        "description": ""
      }
    },
    "recommendations": {
      "type": "product-recommendations",
      "blocks": {
        "header": {
          "type": "text",
          "settings": {
            "text": "<h3>Complete the Setting</h3>",
            "type_preset": "h4",
            "alignment": "left"
          }
        },
        "static-product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 8,
            "border_radius": 16
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": { "image_ratio": "adapt", "border_radius": 16 }
            },
            "product_title": {
              "type": "product-title",
              "settings": { "type_preset": "rte", "font": "var(--font-body--family)", "padding-block-start": 4 }
            },
            "price": {
              "type": "price",
              "settings": { "show_sale_price_first": true, "show_installments": false, "type_preset": "h6" }
            }
          },
          "block_order": ["gallery", "product_title", "price"]
        }
      },
      "block_order": ["header"],
      "settings": {
        "product": "{{ closest.product }}",
        "recommendation_type": "related",
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "max_products": 4,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 12,
        "rows_gap": 24,
        "section_width": "page-width",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "main",
    "trust_bar",
    "faq",
    "recommendations"
  ]
}
